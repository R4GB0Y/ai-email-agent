# --- secrets (required) ---
OPENAI_API_KEY=sk-...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
GMAIL_CREDENTIALS_PATH=config/credentials.json

# --- behavior (optional, defaults shown) ---
CATEGORIES=urgent,client,internal,newsletter,spam
RESPONSE_TONE=formal             # formal | casual | brief
MAX_EMAILS_PER_RUN=20
MIN_PRIORITY_TO_SURFACE=medium   # low | medium | high
SCHEDULE_INTERVAL_MINUTES=15

# --- runtime ---
LOG_LEVEL=INFO
ENV=dev                          # dev | prod
RUN_MODE=pipeline                # pipeline | server
PORT=8080